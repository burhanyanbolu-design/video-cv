# Video CV API - Production Environment Variables
# Copy this to .env.production and fill in your values

# Server Configuration
PORT=3003
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL=postgresql://videocv:CHANGE_THIS_PASSWORD@postgres:5432/videocv_prod
DB_PASSWORD=CHANGE_THIS_PASSWORD

# Redis (for job queues)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Authentication (GENERATE NEW SECRET!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=GENERATE_NEW_SECRET_HERE

# OpenAI API (for transcription and CV extraction)
OPENAI_API_KEY=sk-proj-your-production-key-here

# AWS S3 Storage
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET=video-cv-uploads

# Privacy Policy Version
PRIVACY_POLICY_VERSION=1.0

# Optional: Elasticsearch (for search functionality)
# ELASTICSEARCH_URL=http://localhost:9200
